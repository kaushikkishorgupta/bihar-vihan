# Bihar Vihaan — environment configuration (copy to .env and fill in)
# NEVER commit a real .env or any file containing secrets.

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
# MongoDB connection string (local or Atlas). Do not commit real credentials.
MONGODB_URI=mongodb://localhost:27017/bihar-vihan

# --- Auth ---
# REQUIRED in production. Use a long, random value, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_USER_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=24h

# --- Admin credentials ---
# Username for the admin panel.
ADMIN_USERNAME=admin
# Production: set a bcrypt hash (preferred). Generate with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'your-password'
ADMIN_PASSWORD_HASH=
# Local-dev only fallback (ignored when NODE_ENV=production). Defaults to "admin123".
ADMIN_PASSWORD=

# --- CORS ---
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000,https://bihar-vihan.vercel.app
